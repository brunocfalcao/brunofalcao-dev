{
    "name": "brunocfalcao/brunofalcao-dev",
    "type": "project",
    "description": "The brunofalcao dot dev website",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "packages/eduka/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/laravel/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/brunocfalcao/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "composer",
            "url": "https://nova.laravel.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "aws/aws-sdk-php": "^3.286",
        "brunocfalcao/course-mastering-nova": "dev-master",
        "brunocfalcao/course-nova-advanced-ui": "dev-master",
        "fakerphp/faker": "^1.23",
        "guzzlehttp/guzzle": "^7.5",
        "hapheus/nova-single-value-card": "dev-main",
        "laravel/framework": "^10.8",
        "spatie/laravel-ignition": "^2.0"
    },
    "require-dev": {
        "jubeki/laravel-code-style": "^2.4",
        "laracraft-tech/laravel-schema-rules": "^1.3",
        "nunomaduro/collision": "^7.0",
        "pestphp/pest": "^2.24",
        "pestphp/pest-plugin-laravel": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-require-cmd": [
            "@php artisan eduka:publish-assets"
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "check-style": "php-cs-fixer fix --dry-run --diff",
        "fix-style": "php-cs-fixer fix"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
